{
  "SPAM": {
    "patterns": [
      "lottery prize",
      "winner of our lucky draw",
      "crypto (giveaway|bonus|airdrop)",
      "congratulations! you won",
      "account suspended.*verify now",
      "urgent.*action required.*(bank|account)",
      "unclaimed (money|funds)"
    ],
    "header_rules": [
      { "name": "X-Spam-Flag", "pattern": "YES" },
      { "name": "X-Spam-Status", "pattern": "Yes" }
    ],
    "actions": ["trash"]
  },
  "SOCIAL": {
    "patterns": [
      "facebook",
      "twitter",
      "linkedin",
      "instagram",
      "pinterest",
      "tiktok"
    ],
    "header_rules": [
      { "name": "List-ID", "pattern": "(facebook|twitter|linkedin|instagram)" }
    ],
    "actions": ["label", "mark_read"]
  },
  "WORK": {
    "patterns": [
      "project",
      "meeting",
      "deadline",
      "report",
      "proposal",
      "attachment"
    ],
    "actions": ["label", "mark_important"]
  },
  "UPDATES": {
    "patterns": [
      "newsletter",
      "receipt",
      "invoice",
      "order",
      "shipping",
      "track.*package",
      "statement",
      "bill.*due",
      "payment (received|confirmed)"
    ],
    "header_rules": [
      { "name": "Precedence", "pattern": "(bulk|list)" }
    ],
    "actions": ["label", "mark_read"]
  }
}
